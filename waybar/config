{
    "height": 30, "spacing": 4,
    "modules-left": ["hyprland/workspaces", "custom/media"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["mpd", "idle_inhibitor", "pulseaudio", "custom/updates", "cpu", "memory", "temperature", "backlight", "keyboard-state", "battery", "battery#bat2", "clock", "tray", "custom/power"],
    "hyprland/workspaces": { "disable-scroll": true, "all-outputs": true, "format": "{name}: {icon}", "format-icons": { "1": "яДа", "2": "яЙи", "3": "яДб", "4": "яЖ╝", "5": "яБ╡", "urgent": "яБк", "focused": "яЖТ", "default": "яДС" } },
    "keyboard-state": { "numlock": true, "capslock": true, "format": "{name} {icon}", "format-icons": { "locked": "яАг", "unlocked": "яВЬ" } },
    "mpd": { "format": "{stateIcon} {artist} - {title} яАБ", "format-disconnected": "Desconectado яАБ", "format-stopped": "Parado яАБ", "state-icons": { "paused": "яБМ", "playing": "яБЛ" }, "tooltip-format": "MPD (conectado)" },
    "idle_inhibitor": { "format": "{icon}", "format-icons": { "activated": "яБо", "deactivated": "яБ░" } },
    "tray": { "spacing": 10 },
    "clock": { "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>", "format-alt": "{:%d-%m-%Y}" },
    "cpu": { "format": "{usage}% яЛЫ", "tooltip": false },
    "memory": { "format": "{}% яГЙ" },
    "temperature": { "critical-threshold": 80, "format": "{temperatureC}┬░C {icon}", "format-icons": ["яЭл", "яЛЙ", "яЭй"] },
    "backlight": { "format": "{percent}% {icon}", "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"] },
    "battery": { "states": { "warning": 30, "critical": 15 }, "format": "{capacity}% {icon}", "format-charging": "{capacity}% яЧз", "format-plugged": "{capacity}% яЗж", "format-alt": "{time} {icon}", "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"] },
    "battery#bat2": { "bat": "BAT2" },
    "pulseaudio": { "format": "{volume}% {icon} {format_source}", "format-bluetooth": "{volume}% {icon}яКФ {format_source}", "format-muted": "яЪй {format_source}", "format-source": "{volume}% яД░", "format-source-muted": "яД▒", "format-icons": { "headphone": "яАе", "hands-free": "яЦР", "headset": "яЦР", "phone": "яВХ", "portable": "яВХ", "car": "яЖ╣", "default": ["яАж", "яАз", "яАи"] }, "on-click": "pavucontrol" },
    "custom/media": { "format": "{icon} {text}", "return-type": "json", "max-length": 45, "format-icons": { "spotify": "яЖ╝", "default": "ЁЯОЬ" }, "escape": true, "exec": "playerctl metadata --format '{\"text\": \"{{artist}} - {{title}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F 2>/dev/null", "on-click": "playerctl play-pause" },
    "custom/power": { "format" : "тП╗ ", "tooltip": false, "on-click": "~/.config/waybar/power.sh" },
    "custom/updates": { "format": "яВл {}", "return-type": "json", "exec": "~/.config/waybar/updates.sh", "interval": 3600, "on-click": "kitty -e yay -Syu && killall -SIGUSR2 waybar", "tooltip": true }
}
